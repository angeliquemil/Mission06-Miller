@model Movie

@{
    ViewData["Title"] = "Add a Movie";
}
<!--Add Movie Form-->
<div class="container">
    <h1 class="text-center display-5 fw-bold mt-4">🎬 Add a Movie to the Collection 🎥</h1>
    
    <!--Asp-for with each form input-->
    <form asp-action="AddMovie" method="post" class="mt-4">
        <div class="mb-3">
            <label asp-for="Category" class="form-label"></label>
            <input asp-for="Category" class="form-control" required>
        </div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" required>
        </div>

        <div class="mb-3">
            <label asp-for="Year" class="form-label"></label>
            <input asp-for="Year" class="form-control" type="number" min="1888" max="2099" required>
        </div>

        <div class="mb-3">
            <label asp-for="Director" class="form-label"></label>
            <input asp-for="Director" class="form-control" required>
        </div>

        <div class="mb-3">
            <label asp-for="Rating" class="form-label"></label>
            <select asp-for="Rating" class="form-select" required>
                <option value="" selected disabled>Select a rating</option>
                <option value="G">G</option>
                <option value="PG">PG</option>
                <option value="PG-13">PG-13</option>
                <option value="R">R</option>
            </select>
        </div>

        <div class="form-check mb-3">
            <input asp-for="Edited" class="form-check-input" type="checkbox">
            <label asp-for="Edited" class="form-check-label"></label>
        </div>

        <div class="mb-3">
            <label asp-for="LentTo" class="form-label"></label>
            <input asp-for="LentTo" class="form-control">
        </div>

        <div class="mb-3">
            <label asp-for="Notes" class="form-label"></label>
            <input asp-for="Notes" class="form-control" maxlength="25">
        </div>

        <button type="submit" class="btn btn-primary btn-lg">🎥 Add Movie</button>
    </form>
</div>
