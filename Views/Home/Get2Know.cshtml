@{
    ViewData["Title"] = "Get to Know Joel";
}
<!--Get to Know Joel Page-->
<div class="text-center">
    <h1 class="display-4 fw-bold mt-4">🎤 Get to Know Joel Hilton 🎬</h1>
    
    <p class="fs-5 mt-3">Joel Hilton is not just a movie connoisseur—he's also a comedy mastermind and podcast legend!</p>
    
    <div class="mt-4">
        <a href="https://www.qwcomedy.com/" target="_blank" class="btn btn-success btn-lg me-3">
            🎭 Quick Wits Comedy
        </a>
        <a href="https://baconsale.com/" target="_blank" class="btn btn-danger btn-lg">
            🎙️ Baconsale Podcast
        </a>
    </div>

    <div class="mt-5">
        <a href="https://baconsale.com/" target="_blank">
            <img src="/images/BaconsaleKate.jpg" 
                 alt="Joel Hilton Baconsale" 
                 class="rounded shadow-lg img-fluid mt-3"
                 style="max-width: 400px; transition: transform 0.3s ease-in-out;" 
                 onmouseover="this.style.transform='scale(1.1)'" 
                 onmouseout="this.style.transform='scale(1)'">
        </a>
        <p class="mt-3 text-muted fst-italic">Click the photo to check out Baconsale!</p>
    </div>
</div>